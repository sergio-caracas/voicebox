# =============================================================================
# Voicebox — environment variable reference
# Copy this file to .env and edit as needed.
# The .env file is read by docker-compose automatically.
# NEVER commit .env to git — it's already in .gitignore.
# =============================================================================

# ── Backend ───────────────────────────────────────────────────────────────────

# Directory where voicebox stores its database, voice profiles, and audio files.
# When running in Docker this should be /app/data (mapped to the named volume).
DATA_DIR=/app/data

# ── HuggingFace model cache ───────────────────────────────────────────────────
# Qwen3-TTS model weights (~2-4 GB) are downloaded here on first use.
# When running in Docker this should be /app/hf_cache (mapped to a named volume).
HF_HOME=/app/hf_cache

# ── Model selection ───────────────────────────────────────────────────────────
# Uncomment to pre-select a model at startup instead of downloading on demand.
# Options: Qwen/Qwen3-TTS-12Hz-1.7B-Base  (recommended, ~4 GB)
#          Qwen/Qwen3-TTS-12Hz-0.6B-Base  (faster/smaller, ~2 GB)
# DEFAULT_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-Base

# ── CUDA (GPU) ────────────────────────────────────────────────────────────────
# Uncomment when using docker-compose.cuda.yml
# CUDA_VISIBLE_DEVICES=0
# PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:512
